# =============================================================================
# Docker Compose loads this file from the project directory as `.env` when you
# run `docker compose ...` (for ${VAR} substitution in docker-compose.yml).
#
# Copy to `.env` and edit:
#   cp .env.example .env
#
# --- Host port mapping (Compose only; not read by FastAPI) -----------------
API_PORT=8000
POSTGRES_PORT=5432

# --- Postgres container (must match DATABASE_URL user/password/db name) -----
POSTGRES_USER=grabpic
POSTGRES_PASSWORD=grabpic
POSTGRES_DB=grabpic

# --- API container / FastAPI (Pydantic Settings env names) -------------------
# Inside Compose, Postgres is reachable at hostname `db` on port 5432.
# If you change POSTGRES_* above, update this URL accordingly.
DATABASE_URL=postgresql+psycopg2://grabpic:grabpic@db:5432/grabpic

# Writable paths inside the API container (volume grabpic_data -> /data)
STORAGE_ROOT=/data/storage
INSIGHTFACE_ROOT=/data/insightface

INSIGHTFACE_MODEL=buffalo_l
MATCH_THRESHOLD=0.35
SELFIE_AUTH_THRESHOLD=0.32

API_TITLE=Grabpic API
API_VERSION=1.0.0

# Kaggle slug for scripts/download_lfw.py when run inside the container
KAGGLE_LFW_DATASET_SLUG=jessicali9530/lfw-dataset

# =============================================================================
# Running uvicorn on the HOST (API outside Docker, DB still in Compose)
# =============================================================================
# Use localhost instead of `db`, and local folders — for example:
#
# DATABASE_URL=postgresql+psycopg2://grabpic:grabpic@127.0.0.1:5432/grabpic
# STORAGE_ROOT=./data/storage
# INSIGHTFACE_ROOT=./data/insightface
#
# Start only Postgres:  docker compose up -d db
# Then from the host:   uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
